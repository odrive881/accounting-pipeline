# .env.example
# Copy this file to .env and fill in real values.

# Airflow
AIRFLOW_UID=50000

# Postgres — accounting-db service
DB_USER=accounting_user
DB_PASSWORD=changeme
DB_NAME=accounting_pipeline
DB_HOST=accounting-db
DB_PORT=5432   # internal port — used by dbt and loader.py, inside the Docker network
DB_HOST_PORT=5433    # host-side port — used only by docker-compose.yaml's port mapping